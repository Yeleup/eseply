DOCKER_PROJECT_NAME=laravel-app

APP_NAME="Laravel App"
APP_ENV=local
APP_DEBUG=true
APP_PORT=8500
APP_URL=http://localhost:8500

DB_CONNECTION=mysql
DB_DATABASE=laravel_app
DB_USERNAME=laravel
DB_PASSWORD=laravel
DB_ROOT_PASSWORD=root
FORWARD_DB_PORT=3350
MARIADB_TEST_DATABASE=laravel_app_testing

CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_CLIENT=phpredis

VITE_PORT=5174
VITE_HMR_HOST=localhost

RUN_MIGRATIONS=1
